# Base URLs of the deployed remotes (NO trailing /assets/remoteEntry.js — the
# shell appends that). Leave these unset for local dev; vite.config.ts falls
# back to the localhost preview ports (3001/3002/3003).
#
# On Vercel, set these in the shell project's Environment Variables to the
# deployed remote domains, e.g.:
VITE_HEADLINES_URL=https://your-headlines.vercel.app
VITE_BOOKMARKS_URL=https://your-bookmarks.vercel.app
VITE_WEATHER_URL=https://your-weather.vercel.app
